{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "rust: cargo build",
      "type": "shell",
      "command": "cargo build",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "rust: cargo test",
      "type": "shell",
      "command": "cargo test",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "rust: cargo clippy",
      "type": "shell",
      "command": "cargo clippy --all-targets -- -D warnings",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "rust: cargo fmt",
      "type": "shell",
      "command": "cargo fmt",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "rust: openapi-gen",
      "type": "shell",
      "command": "cargo run --bin openapi-gen",
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "problemMatcher": ["$rustc"]
    }
  ]
}
