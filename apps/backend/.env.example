# Database
DATABASE_URL=postgres://user:password@localhost:5432/gaming_cafe
DATABASE_MAX_CONNECTIONS=10

# Auth
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long

# Server
PORT=3000

# Timezone
CAFE_TZ=Asia/Kolkata

# ZeptoMail (OTP delivery)
ZEPTOMAIL_TOKEN=

# Object storage for game media assets (DRAFT-0022).
# S3-compatible endpoint (AWS S3, Cloudflare R2, MinIO, etc.). Presigned PUT URLs
# are issued for direct browser uploads; only the URLs are stored in the DB.
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
# Optional public base for stored URLs (defaults to {STORAGE_ENDPOINT}/{STORAGE_BUCKET}).
STORAGE_PUBLIC_URL=
# Presigned URL lifetime in seconds (default 900).
STORAGE_PRESIGN_EXPIRY_SECS=900
