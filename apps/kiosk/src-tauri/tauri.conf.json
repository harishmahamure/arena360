{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arena360 Station Management",
  "version": "5.0.0",
  "identifier": "com.gamingcafe.kiosk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "pnpm turbo run build --filter=@gaming-cafe/kiosk",
      "cwd": "../.."
    },
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Arena360 Station Management Application",
        "width": 1280,
        "height": 720,
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3000 https://api.arena360.cloud wss://api.arena360.cloud ws://localhost:3000 https://cdn.arena360.cloud; img-src 'self' asset: https://cdn.arena360.cloud data:; media-src 'self' asset: https://cdn.arena360.cloud blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPCACHE/assets/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Arena360",
    "category": "Game",
    "shortDescription": "Locked-down Arena360 Station Management Application",
    "longDescription": "Arena360 Station Management Application: device registration, player sessions, lockdown and launcher for gaming cafe stations.",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
