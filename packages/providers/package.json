{
  "name": "@gaming-cafe/providers",
  "version": "0.0.0",
  "private": true,
  "description": "Shared React providers: theme, toast, error boundary, query client.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@gaming-cafe/tsconfig": "workspace:*",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "dependencies": {
    "@gaming-cafe/utils": "workspace:*",
    "@gaming-cafe/theme": "workspace:*",
    "@mui/material": "^7.3.6",
    "react-toastify": "^11.0.5"
  },
  "peerDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
