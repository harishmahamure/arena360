{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["@gaming-cafe/biome-config"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.turbo",
      "!**/.next",
      "!**/coverage",
      "!**/src-tauri/target",
      "!**/apps/backend/target",
      "!**/target",
      "!**/*.lock",
      "!**/openapi.json",
      "!**/schema.ts"
    ]
  }
}
