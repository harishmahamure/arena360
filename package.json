{
  "name": "gaming-cafe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "gen:api-types": "tsx scripts/gen-api-types.ts",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@gaming-cafe/biome-config": "workspace:*",
    "@gaming-cafe/tsconfig": "workspace:*",
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.27.10",
    "@types/node": "^20.17.10",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "~5.6.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec biome check --staged --no-errors-on-unmatched"
  }
}
