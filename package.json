{
  "name": "gaming-cafe",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/admin",
    "apps/kiosk",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "gen:api-types": "tsx scripts/gen-api-types.ts",
    "gen:bruno": "tsx scripts/gen-bruno-collection.ts",
    "migration": "tsx scripts/migration.ts",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "simple-git-hooks",
    "admin:dev": "pnpm --filter @gaming-cafe/admin dev",
    "admin:build": "pnpm --filter @gaming-cafe/admin build",
    "backend:build": "cargo build --manifest-path apps/backend/Cargo.toml",
    "backend:build:release": "cargo build --release --manifest-path apps/backend/Cargo.toml",
    "backend:dev": "cargo run --manifest-path apps/backend/Cargo.toml",
    "backend:run": "cargo run --manifest-path apps/backend/Cargo.toml",
    "backend:test": "cargo test --manifest-path apps/backend/Cargo.toml",
    "backend:clippy": "cargo clippy --all-targets --manifest-path apps/backend/Cargo.toml -- -D warnings",
    "backend:fmt": "cargo fmt --manifest-path apps/backend/Cargo.toml",
    "kiosk:dev": "pnpm --filter @gaming-cafe/kiosk tauri:dev",
    "kiosk:build": "pnpm --filter @gaming-cafe/kiosk tauri:build",
    "console-tv:assemble": "cd apps/console-tv && ./gradlew :app:assembleDebug",
    "console-tv:uninstall": "adb uninstall com.gamingcafe.consoletv || true",
    "console-tv:install": "cd apps/console-tv && ./gradlew :app:generateDebugBuildConfig :app:installDebug",
    "console-tv:run": "pnpm console-tv:uninstall && pnpm console-tv:install && adb shell am start -n com.gamingcafe.consoletv/.MainActivity"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.27.10",
    "@gaming-cafe/biome-config": "workspace:*",
    "@gaming-cafe/tsconfig": "workspace:*",
    "@types/node": "^20.17.10",
    "pg": "^8.21.0",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "~5.6.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bash scripts/pre-commit-biome.sh"
  }
}
